# Anthropic API Key — von https://console.anthropic.com/ holen
ANTHROPIC_API_KEY=sk-ant-...

# Datenbank-Pfad (im Container — nicht ändern, ausser du weisst was du tust)
DATABASE_URL=sqlite:////data/db/meal_planner.db

# Fernet-Schlüssel zum Verschlüsseln von CalDAV-Credentials
# Erzeugen mit: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Logging
LOG_LEVEL=INFO

# Open Food Facts — Pflicht-Header laut OFF-Policy
OFF_USER_AGENT=MealPlanner/0.1 (selfhosted)
